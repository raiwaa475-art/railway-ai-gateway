PORT=3000
GATEWAY_API_KEY=local-dev-key
GATEWAY_ADMIN_KEY=change-me
ALLOW_PRIVATE_PROVIDER_URL=false
DEFAULT_PROVIDER_ID=deepseek

DEEPSEEK_API_KEY=
DEFAULT_MODEL=deepseek-v4-flash

# Dynamic Local AI Provider Settings
QWEN_LOCAL_API_URL=http://localhost:11434/v1
QWEN_LOCAL_MODEL=qwen2.5-coder-3b-instruct
QWEN_LOCAL_MAX_TOKENS=32000
QWEN_LOCAL_TIMEOUT_MS=180000
QWEN_ONLY_LOW_RISK_ENABLED=false
ALLOW_RAILWAY_DISK_FILE_CONTEXT=false

# Qwen Agent & Tuning Settings
QWEN_AGENT_ENABLED=true
QWEN_AGENT_MAX_TOOL_ROUNDS=8
QWEN_AGENT_TOOL_RETRY_LIMIT=1
QWEN_AGENT_TRACE_ENABLED=true
QWEN_AGENT_TRACE_SANITIZE=true
QWEN_AGENT_TRACE_MAX_CHARS=20000

# Smart Controller Settings
SMART_CONTROLLER_ENABLED=true
SMART_CONTROLLER_MODEL=deepseek-v4-flash
SMART_CONTROLLER_MAX_REVIEW_ROUNDS=2
SMART_CONTROLLER_ALLOW_CLAUDE=false

# Auto Coding Workflow Settings
AUTO_CODING_ENABLED=false
AUTO_CODING_MAX_STEPS=12
AUTO_CODING_REQUIRE_HUMAN_APPROVAL=true

DATABASE_URL=
USD_THB_RATE=35.0
DEEPSEEK_INPUT_CACHE_HIT_USD_PER_1M=0.0028
DEEPSEEK_INPUT_CACHE_MISS_USD_PER_1M=0.14
DEEPSEEK_OUTPUT_USD_PER_1M=0.28

# Model-specific overrides (optional)
# DEEPSEEK_V4_FLASH_INPUT_CACHE_HIT_USD_PER_1M=0.0028
# DEEPSEEK_V4_FLASH_INPUT_CACHE_MISS_USD_PER_1M=0.14
# DEEPSEEK_V4_FLASH_OUTPUT_USD_PER_1M=0.28
# DEEPSEEK_V4_PRO_INPUT_CACHE_HIT_USD_PER_1M=0.003625
# DEEPSEEK_V4_PRO_INPUT_CACHE_MISS_USD_PER_1M=0.435
# DEEPSEEK_V4_PRO_OUTPUT_USD_PER_1M=0.87

